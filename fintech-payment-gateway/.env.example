# Database
MONGODB_URI=mongodb://localhost:27017/fintech_gateway
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=replace-with-a-long-random-secret
ENCRYPTION_KEY=replace-with-at-least-32-characters

# Blockchain
INFURA_PROJECT_ID=your-infura-project-id
ETHERSCAN_API_KEY=your-etherscan-api-key
COINMARKETCAP_API_KEY=your-coinmarketcap-api-key

# Payment Providers
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Email (OTP Verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_app_password_without_spaces
SMTP_FROM=FinPay <no-reply@yourdomain.com>
EMAIL_OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60

# Optional email fallback provider (recommended for production)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
RESEND_FROM=FinPay <no-reply@yourdomain.com>

# Compliance
KYC_API_KEY=your_kyc_provider_key
AML_API_KEY=your_aml_provider_key

# Server
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173
