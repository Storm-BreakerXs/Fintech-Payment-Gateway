# Database
MONGODB_URI=mongodb://localhost:27017/fintech_gateway
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=replace-with-a-long-random-secret
ENCRYPTION_KEY=replace-with-at-least-32-characters

# Blockchain
INFURA_PROJECT_ID=your-infura-project-id
ETHERSCAN_API_KEY=your-etherscan-api-key
COINMARKETCAP_API_KEY=your-coinmarketcap-api-key

# Payment Providers
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Email (OTP Verification)
SMTP_HOST=mail.finpay.com.ng
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=support@finpay.com.ng
SMTP_PASS=your_mailbox_password
SMTP_FROM=FinPay Support <support@finpay.com.ng>
EMAIL_OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
PASSWORD_RESET_TTL_MINUTES=30
ACCOUNT_DELETION_GRACE_HOURS=24

# Optional email fallback provider (recommended for production)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
RESEND_FROM=FinPay Support <support@finpay.com.ng>
SALES_INBOX=sales@finpay.com.ng

# CRM Lead Routing (optional)
# Generic webhook (works with Zapier, Make, custom CRM middleware, etc.)
CRM_WEBHOOK_URL=
CRM_WEBHOOK_AUTH_HEADER=Authorization
CRM_WEBHOOK_AUTH_TOKEN=
CRM_WEBHOOK_SECRET=
CRM_LEAD_SOURCE_LABEL=FinPay Contact Sales Form

# HubSpot forms API (set both to enable HubSpot delivery)
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_ID=
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_FIELD_MONTHLY_VOLUME=monthly_volume
HUBSPOT_FIELD_PREFERRED_CONTACT=preferred_contact
HUBSPOT_FIELD_LEAD_SOURCE=lead_source

# Salesforce webhook (Flow/Apex REST endpoint)
SALESFORCE_LEAD_WEBHOOK_URL=
SALESFORCE_API_TOKEN=
SALESFORCE_FIELD_MONTHLY_VOLUME=Monthly_Volume__c
SALESFORCE_FIELD_PREFERRED_CONTACT=Preferred_Contact__c

# Compliance
KYC_API_URL=https://your-kyc-provider.example.com/verify
KYC_API_KEY=your_kyc_provider_key

# Crypto swap provider
SWAP_PROVIDER_BASE_URL=https://api.0x.org
SWAP_PROVIDER_API_KEY=

# Server
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173,https://finpay.com.ng,https://www.finpay.com.ng
